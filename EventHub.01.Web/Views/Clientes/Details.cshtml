@model EventHub._02.Bussines.DTOs.ClienteDto
@{
    ViewBag.Title = Model.Nombre;
    var eventos = ViewBag.Eventos as List<EventHub._02.Bussines.DTOs.EventoListDto>;
}

<div class="client-dashboard">
    <!-- Client Banner -->
    <div class="client-banner">
        <div class="client-banner__bg"></div>
        <div class="client-banner__content">
            <div class="client-banner__info">
                <div class="client-banner__header">
                    <h1>@Model.Nombre</h1>
                    <span class="badge" style="background:@(Model.Estado ? "#059669" : "#dc2626");color:#fff;">@(Model.Estado ? "Activo" : "Inactivo")</span>
                </div>
                <div class="client-banner__meta">
                    <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg> RUC: @Model.Ruc</span>
                    <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg> @Model.Email</span>
                    @if (!string.IsNullOrEmpty(Model.Telefono))
                    {
                        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg> @(Model.Telefono ?? "-")</span>
                    @if (!string.IsNullOrEmpty(Model.Contacto))
                    {
                        <span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Contacto: @Model.Contacto</span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.Direccion))
                {
                    <div class="client-banner__address">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        @Model.Direccion
                    </div>
                }
            </div>
            <div class="client-banner__actions">
                <a href="@Url.Action("Index")" class="btn btn-outline btn-sm" style="border-color:rgba(255,255,255,0.3);color:#fff;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    Volver
                </a>
                <button type="button" class="btn btn-primary btn-sm edit-client-btn" data-id="@Model.Id" data-nombre="@Model.Nombre" data-ruc="@Model.Ruc" data-email="@Model.Email" data-telefono="@Model.Telefono" data-direccion="@Model.Direccion" data-contacto="@Model.Contacto" data-clasificacion="@Model.Clasificacion">Editar</button>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="client-stats-grid">
        <div class="stat-card">
            <div class="stat-card__icon" style="background:#dbeafe;color:#2563eb;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="stat-card__value">@(eventos?.Count ?? 0)</div>
            <div class="stat-card__label">Total Eventos</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__icon" style="background:#d1fae5;color:#059669;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div class="stat-card__value">@(eventos?.Count(e => e.Estado == "Finalizado") ?? 0)</div>
            <div class="stat-card__label">Finalizados</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__icon" style="background:#fef3c7;color:#d97706;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="stat-card__value">@(eventos?.Count(e => e.Estado != "Finalizado" && e.Estado != "Cancelado") ?? 0)</div>
            <div class="stat-card__label">Activos</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__icon" style="background:#fee2e2;color:#dc2626;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            </div>
            <div class="stat-card__value">@(eventos?.Count(e => e.Estado == "Cancelado") ?? 0)</div>
            <div class="stat-card__label">Cancelados</div>
        </div>
    </div>

    <!-- Events Table -->
    <div class="card" style="margin:0 32px;">
        <h3 style="margin:0 0 16px 0;font-size:18px;font-weight:700;">Eventos del Cliente</h3>
        @if (eventos != null && eventos.Count > 0)
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Evento</th>
                        <th>Lugar</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Presupuesto</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in eventos)
                    {
                        <tr class="event-row" data-href="@Url.Action("Details", "Eventos", new { id = evt.Id })" style="cursor:pointer;">
                            <td style="font-weight:600;font-size:13px;">@evt.Codigo</td>
                            <td><a href="@Url.Action("Details", "Eventos", new { id = evt.Id })" style="color:var(--primary);text-decoration:none;font-weight:600;">@evt.Nombre</a></td>
                            <td>@evt.VenueNombre</td>
                            <td>@evt.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge badge-@evt.Estado.ToLower()">@evt.Estado</span></td>
                            <td>@evt.PresupuestoEstimado.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p style="text-align:center;color:var(--text-muted);padding:32px;">Este cliente no tiene eventos registrados.</p>
        }
    </div>
</div>

<!-- Client Edit Modal -->
<div id="clientModal" class="modal-overlay" style="display:none;">
    <div class="modal-panel">
        <div class="modal-header">
            <button type="button" id="closeClientModal" class="modal-close-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
            <h3>Editar Cliente</h3>
        </div>
        <div class="modal-body">
            <form id="clientForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="clienteId" name="Id" />
                <div class="form-group">
                    <label>Nombre *</label>
                    <input type="text" id="clienteNombre" name="Nombre" class="form-control" required maxlength="150" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>RUC *</label>
                        <input type="text" id="clienteRuc" name="Ruc" class="form-control" maxlength="13" required />
                    </div>
                    <div class="form-group">
                        <label>Clasificación</label>
                        <select id="clienteClasificacion" name="Clasificacion" class="form-control">
                            <option value="Nuevo">Nuevo</option>
                            <option value="Regular">Regular</option>
                            <option value="VIP">VIP</option>
                            <option value="Estrategico">Estratégico</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" id="clienteEmail" name="Email" class="form-control" required maxlength="100" />
                    </div>
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input type="text" id="clienteTelefono" name="Telefono" class="form-control" maxlength="20" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Contacto</label>
                    <input type="text" id="clienteContacto" name="Contacto" class="form-control" maxlength="150" />
                </div>
                <div class="form-group">
                    <label>Dirección</label>
                    <input type="text" id="clienteDireccion" name="Direccion" class="form-control" maxlength="200" />
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button type="button" id="cancelClientModal" class="btn btn-outline">Cancelar</button>
            <button type="button" id="saveClientBtn" class="btn btn-primary">Guardar Cambios</button>
        </div>
    </div>
</div>

<style>
    .client-dashboard {
        margin: -24px -32px;
    }
    .client-banner {
        position: relative;
        width: 100%;
        height: 280px;
        overflow: hidden;
        background: var(--sidebar-bg);
    }
    .client-banner__bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, #1e293b 0%, #334155 50%, #475569 100%);
    }
    .client-banner__content {
        position: relative;
        z-index: 1;
        height: 100%;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        padding: 32px;
        background: linear-gradient(to top, rgba(15,23,42,0.9) 0%, transparent 100%);
        color: white;
    }
    .client-banner__header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }
    .client-banner__header h1 {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #fff;
    }
    .client-banner__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 8px;
        font-size: 14px;
        color: rgba(255,255,255,0.85);
    }
    .client-banner__meta span {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .client-banner__address {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: rgba(255,255,255,0.7);
    }
    .client-banner__actions {
        display: flex;
        gap: 8px;
    }
    .client-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        padding: 32px;
    }
    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
    }
    .stat-card__icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
    }
    .stat-card__value {
        font-size: 28px;
        font-weight: 700;
        color: var(--text);
    }
    .stat-card__label {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 4px;
    }
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.5);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0;
    }
    .modal-panel {
        width: 480px;
        max-width: 100vw;
        height: 100vh;
        background: var(--bg-card);
        display: flex;
        flex-direction: column;
        animation: slideIn 0.25s ease;
    }
    @@keyframes slideIn {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }
    .modal-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 20px 24px;
        border-bottom: 1px solid var(--border);
    }
    .modal-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
    }
    .modal-close-btn {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        padding: 4px;
        border-radius: 4px;
    }
    .modal-close-btn:hover {
        color: var(--text);
        background: var(--bg);
    }
    .modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
    }
    .modal-footer {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        padding: 16px 24px;
        border-top: 1px solid var(--border);
    }
    @@media (max-width: 768px) {
        .client-banner {
            height: 240px;
        }
        .client-banner__content {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
            padding: 24px;
        }
        .client-banner__header h1 {
            font-size: 22px;
        }
        .client-stats-grid {
            grid-template-columns: repeat(2, 1fr);
            padding: 24px;
        }
    }
</style>

@section scripts {
    <script>
        document.querySelectorAll('.event-row').forEach(function(row) {
            row.addEventListener('click', function(e) {
                if (e.target.closest('a, button')) return;
                window.location.href = row.dataset.href;
            });
        });

        var clientModal = document.getElementById('clientModal');
        var editBtn = document.querySelector('.edit-client-btn');

        editBtn.addEventListener('click', function() {
            document.getElementById('clienteId').value = editBtn.dataset.id;
            document.getElementById('clienteNombre').value = editBtn.dataset.nombre;
            document.getElementById('clienteRuc').value = editBtn.dataset.ruc;
            document.getElementById('clienteEmail').value = editBtn.dataset.email;
            document.getElementById('clienteTelefono').value = editBtn.dataset.telefono || '';
            document.getElementById('clienteDireccion').value = editBtn.dataset.direccion || '';
            document.getElementById('clienteContacto').value = editBtn.dataset.contacto || '';
            document.getElementById('clienteClasificacion').value = editBtn.dataset.clasificacion || 'Nuevo';
            clientModal.style.display = 'flex';
        });

        document.getElementById('closeClientModal').addEventListener('click', function() {
            clientModal.style.display = 'none';
        });
        document.getElementById('cancelClientModal').addEventListener('click', function() {
            clientModal.style.display = 'none';
        });

        document.getElementById('saveClientBtn').addEventListener('click', function() {
            var form = document.getElementById('clientForm');
            var formData = new FormData(form);
            var token = form.querySelector('input[name="__RequestVerificationToken"]');
            if (token) formData.append('__RequestVerificationToken', token.value);

            fetch('@Url.Action("EditAjax", "Clientes")', {
                method: 'POST',
                body: formData
            })
            .then(function(response) { return response.json(); })
            .then(function(data) {
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.message || 'Error al guardar');
                }
            })
            .catch(function() {
                alert('Error de conexión');
            });
        });
    </script>
}
