@model EventHub._01.Web.Models.RegisterViewModel

@{
    ViewBag.Title = "Crear Cuenta";
}

@using (Html.BeginForm("Register", "Auth", FormMethod.Post, new { role = "form" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(m => m.Nombre)
        <div class="input-wrapper">
            <span class="input-icon">
                <!-- User Icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </span>
            @Html.TextBoxFor(m => m.Nombre, new { @class = "", placeholder = "Juan Pérez", autofocus = "" })
        </div>
        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "field-error" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Alias)
        <div class="input-wrapper">
            <span class="input-icon">
                <!-- Badge/Icon Icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2a10 10 0 1 0 0 20 10A10 10 0 0 0 12 2z"/>
                    <path d="M2 12h20"/>
                    <path d="M12 2v20"/>
                </svg>
            </span>
            @Html.TextBoxFor(m => m.Alias, new { @class = "", placeholder = "juanperez" })
        </div>
        @Html.ValidationMessageFor(m => m.Alias, "", new { @class = "field-error" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Email)
        <div class="input-wrapper">
            <span class="input-icon">
                <!-- Email Icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 1 2 2v12c0 1-1 2-2 2H4c-1 0-2-1-2-2V6c0-1 1-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
            </span>
            @Html.TextBoxFor(m => m.Email, new { @class = "", placeholder = "tu@email.com", autocomplete = "email" })
        </div>
        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Telefono)
        <div class="input-wrapper">
            <span class="input-icon">
                <!-- Phone Icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2.18h-15a2 2 0 0 1-2.18-2.18v-3a2 2 0 0 1 2.18-2.18h15a2 2 0 0 1 2.18 2.18z"/>
                    <polyline points="15,9 15,2 9,9"/>
                </svg>
            </span>
            @Html.TextBoxFor(m => m.Telefono, new { @class = "", placeholder = "0999-999-999" })
        </div>
        @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "field-error" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Password)
        <div class="input-wrapper">
            <span class="input-icon">
                <!-- Lock Icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="10" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </span>
            @Html.PasswordFor(m => m.Password, new { @class = "", placeholder = "Mínimo 8 caracteres", autocomplete = "new-password", id = "registerPassword" })
            <button type="button" class="toggle-password" onclick="togglePassword('registerPassword', this)" tabindex="-1" aria-label="Mostrar contraseña">
                <svg class="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
            </button>
        </div>
        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
        <div class="strength-bar" id="passwordStrength">
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
            <div class="bar"></div>
        </div>
        <div class="strength-text" id="strengthText"></div>
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.ConfirmPassword)
        <div class="input-wrapper">
            <span class="input-icon">
                <!-- Lock Icon (same as password) -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="10" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </span>
            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "", placeholder = "Repite la contraseña", autocomplete = "new-password", id = "confirmPassword" })
            <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword', this)" tabindex="-1" aria-label="Mostrar contraseña">
                <svg class="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
            </button>
        </div>
        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-error" })
    </div>

    <button type="submit" class="btn-primary" id="registerSubmit">
        <span class="spinner"></span>
        <span class="btn-text">Crear Cuenta</span>
    </button>
}

@section AuthFooter {
    <p>¿Ya tienes cuenta? <a href="/Auth/Login" style="font-weight: 600;">Inicia Sesión</a></p>
}

@section scripts {
    <script>
        document.getElementById('registerPassword').addEventListener('input', function() {
            var val = this.value;
            var bars = document.querySelectorAll('#passwordStrength .bar');
            var strengthText = document.getElementById('strengthText');
            var score = 0;
            if (val.length >= 8) score++;
            if (/[a-z]/.test(val)) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/\\d/.test(val)) score++;

            var labels = ['', 'Débil', 'Regular', 'Buena', 'Fuerte'];
            var colors = ['', '#ef4444', '#f59e0b', '#06d6a0', '#10b981'];

            for (var i = 0; i < bars.length; i++) {
                var bar = bars[i];
                if (i < score) {
                    bar.classList.add('active');
                    bar.style.background = colors[score] || colors[4];
                } else {
                    bar.classList.remove('active');
                    bar.style.background = '';
                }
            }

            if (val.length === 0) {
                strengthText.textContent = '';
                return;
            }

            strengthText.textContent = labels[score] || labels[4];
            strengthText.style.color = colors[score] || colors[4];
        });
        document.querySelector('form[role="form"]').addEventListener('submit', function() {
            var btn = document.getElementById('registerSubmit');
            btn.classList.add('loading');
            btn.disabled = true;
        });
    </script>
}