@model EventHub._01.Web.Models.ForgotPasswordViewModel

@{
    ViewBag.Title = "Recuperar Contraseña";
}

<p style="color: var(--text-secondary); margin-bottom: 24px; font-size: 14px;">
    Ingresa tu email y te enviaremos un código de verificación para restablecer tu contraseña.
</p>

@using (Html.BeginForm("ForgotPassword", "Auth", FormMethod.Post, new { role = "form" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(m => m.Email)
        @Html.TextBoxFor(m => m.Email, new { @class = "", placeholder = "tu@email.com", autocomplete = "email", autofocus = "" })
        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger", style = "font-size: 12px; margin-top: 4px; display: block;" })
    </div>

    <button type="submit" class="btn-primary">Enviar Código</button>
}

@section AuthFooter {
    <p>@Html.ActionLink("Volver al inicio de sesión", "Login")</p>
}
