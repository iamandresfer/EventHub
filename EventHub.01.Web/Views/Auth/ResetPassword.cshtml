@model EventHub._01.Web.Models.ResetPasswordViewModel

@{
    ViewBag.Title = "Restablecer Contraseña";
}

<p style="color: var(--text-secondary); margin-bottom: 24px; font-size: 14px;">
    Ingresa tu nueva contraseña. Debe tener al menos 8 caracteres con una mayúscula, una minúscula y un número.
</p>

@using (Html.BeginForm("ResetPassword", "Auth", FormMethod.Post, new { role = "form" }))
{
    @Html.AntiForgeryToken()

    <div class="form-group">
        @Html.LabelFor(m => m.NewPassword)
        <div class="password-wrapper">
            @Html.PasswordFor(m => m.NewPassword, new { @class = "", placeholder = "Nueva contraseña", autocomplete = "new-password", autofocus = "", id = "newPassword" })
            <button type="button" class="toggle-password" onclick="togglePassword('newPassword', this)" tabindex="-1">
                <svg class="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
        </div>
        @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger", style = "font-size: 12px; margin-top: 4px; display: block;" })
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.ConfirmPassword)
        <div class="password-wrapper">
            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "", placeholder = "Repite la contraseña", autocomplete = "new-password", id = "confirmPasswordReset" })
            <button type="button" class="toggle-password" onclick="togglePassword('confirmPasswordReset', this)" tabindex="-1">
                <svg class="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
        </div>
        @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger", style = "font-size: 12px; margin-top: 4px; display: block;" })
    </div>

    <button type="submit" class="btn-primary">Restablecer Contraseña</button>
}

@section AuthFooter {
    <p>@Html.ActionLink("Volver al inicio de sesión", "Login")</p>
}
